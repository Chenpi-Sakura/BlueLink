# ===== LLM API =====
# OpenAI 兼容协议，填 DeepSeek / Moonshot / OpenAI / 硅基流动 等
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_CHAT_MODEL=deepseek-chat
LLM_EMBED_MODEL=embedding-v1
# LLM_EMBED_BASE_URL=
# LLM_EMBED_API_KEY=

LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SEC=30

# ===== 数据库 =====
# 生产用 PostgreSQL，本地开发可切 SQLite
DATABASE_URL=postgresql://bluelink:bluelink@localhost:5432/bluelink
# DATABASE_URL=sqlite:///./bluelink.db

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
VECTOR_DIMENSION=1024

# ===== 存储 =====
UPLOADS_DIR=./uploads
BLUELINK_FERNET_KEY=

# ===== 服务 =====
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ENV=development

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== Docker 部署用（docker compose 自动读取）=====
# POSTGRES_PASSWORD=bluelink

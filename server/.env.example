# LLM API — OpenAI 兼容协议，不绑定厂商
# 以下示例用 DeepSeek，换成 Moonshot / OpenAI / 硅基流动 等只需改 URL 和 Key
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_CHAT_MODEL=deepseek-chat
LLM_EMBED_MODEL=embedding-v1
# LLM_EMBED_BASE_URL=      # 可选，独立 embedding 地址（默认同 LLM_BASE_URL）
# LLM_EMBED_API_KEY=       # 可选，独立 embedding 密钥（默认同 LLM_API_KEY）

LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SEC=30

DATABASE_URL=sqlite:///./bluelink.db
VECTORS_DIR=./vectors
UPLOADS_DIR=./uploads
BLUELINK_FERNET_KEY=

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ENV=development

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
